[
  {
    "label": "Debug in -dd mode",
    "build": {
      "command": "cargo",
      "args": ["build"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/ecdump",
    "args": ["-f", "pcap/ecat_safe_op_fail_filtered.pcap", "-dd"],
    // sourceLanguages is required for CodeLLDB (not GDB) when using Rust
    "sourceLanguages": ["rust"],
    "request": "launch",
    "adapter": "CodeLLDB",
  },
  {
    "label": "Debug in -vv mode",
    "build": {
      "command": "cargo",
      "args": ["build"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/ecdump",
    "args": ["-f", "pcap/20251226_164027.pcap", "-vv"],
    // sourceLanguages is required for CodeLLDB (not GDB) when using Rust
    "sourceLanguages": ["rust"],
    "request": "launch",
    "adapter": "CodeLLDB",
  },
  {
    "label": "Debug in -vv mode 2",
    "build": {
      "command": "cargo",
      "args": ["build"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/ecdump",
