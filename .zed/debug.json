[
  {
    "label": "Build and Debug ecdump in file mode with CodeLLDB",
    "build": {
      "command": "cargo",
      "args": ["build"],
    },
    "program": "$ZED_WORKTREE_ROOT/target/debug/ecdump",
    "args": ["-f", "pcap/ecat_safe_op_fail_filtered.pcap", "-dd"],
    // sourceLanguages is required for CodeLLDB (not GDB) when using Rust
    "sourceLanguages": ["rust"],
    "request": "launch",
    "adapter": "CodeLLDB",
  },
]
